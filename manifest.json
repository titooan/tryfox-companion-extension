{
  "manifest_version": 2,
  "name": "tryfox-companion",
  "version": "0.0.1",
  "description": "Generate QR for TryFox",
  "homepage_url": "https://github.com/titooan/tryfox-companion-extension/",
  "icons": {
    "16": "icons/tryfox.png",
    "32": "icons/tryfox.png",
    "64": "icons/tryfox.png"
  },
  "permissions": ["activeTab", "downloads", "storage"],
  "optional_permissions": ["http://*/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "tryfox-companion@titouan",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "browser_action": {
    "browser_style": true,
    "default_icon": {
      "16": "icons/tryfox.png",
      "32": "icons/tryfox.png",
      "64": "icons/tryfox.png"
    },
    "default_title": "fxqrl",
    "default_popup": "popup/fxqrl.html"
  },

  "background": {
    "scripts": [
      "src/pairing/androidLanPayload.js",
      "src/pairing/lanAuth.js",
      "src/background/lanClient.js",
      "src/background/background.js"
    ]
  },

  "options_ui": {
    "page": "settings/options.html"
  }
}
